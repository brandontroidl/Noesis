debug = false
# ==========================================================================
# Acid — Example Configuration
# ==========================================================================
# Copyright (c) Cathexis Development
#
# MINIMUM changes required:
#   1. [server]  — name, numeric, description
#   2. [uplink]  — host, port, password (must match ircd Connect block)
#   3. [uplink]  — hmac_key (must match link password for HMAC signing)
#   4. [services.privileges] — owners list
# ==========================================================================

[server]
name        = "acid.example.org"
numeric     = 10
description = "Network Services"
max_clients = 64
db_encryption_key = ""

[uplink]
host     = "127.0.0.1"
port     = 4401
password = "$LINK_PASSWORD"
tls      = true
tls_skip_verify = true

# S2S HMAC — signs every outgoing P10 line with HMAC-SHA256.
# Only needed if the ircd Connect block has "hmac = yes".
hmac_key        = "$LINK_PASSWORD"
hmac_scheme     = "cathexis-s2s-hmac-v1"
hmac_key_derive = "hmac-sha256"

[services]
prefix = "!"

[services.privileges]
owners = ["admin"]
admins = []
opers  = []

[services.flood]
max_per_second = 5
max_burst      = 10
cooldown_secs  = 30

[ircv3]
enable_tags      = true
enable_bot_mode  = true

# --- Modules ---

[modules.rootserv]
enabled = true
nick    = "RootServ"
ident   = "root"
gecos   = "Services Root Administration"

[modules.moo]
enabled = true
nick    = "Moo"
ident   = "moo"
gecos   = "Network Monitoring Service"

[modules.dronescan]
enabled = true
nick    = "DroneScan"
ident   = "drone"
gecos   = "Drone Detection Service"

[modules.limitserv]
enabled = true
nick    = "LimitServ"
ident   = "limitserv"
gecos   = "Channel Limit Service"
padding = 5
interval = 60

[modules.trapbot]
enabled  = true
nick     = "Trap"
ident    = "trap"
gecos    = "Trap Channel Monitor"
channels = ["#trap1"]
action   = "gline"
duration = 86400
reason   = "Trapped: unauthorized channel access"

[modules.vizon]
enabled = true
nick    = "V"
ident   = "vizon"
gecos   = "Network Monitor"

[modules.ctcp]
enabled       = true
version_reply = "Acid Services"

[modules.dnsbl]
enabled = false

[modules.proxyscan]
enabled = false

[modules.track]
enabled = true
channel = "#opers"

[modules.webhooks]
enabled = false

# ─────────────────────────────────────────────────────────────────────
# Sentinel — abuse-detection module
#
# Parses Cathexis 1.5.6+ extended DNSBL marks ("DNSBL|zone1|zone2"),
# sums per-zone weights to produce a score, and drives automated
# warn/gline response. Scores accumulate across zones hit by the same
# connection, so a host listed in multiple RBLs gets harsher treatment.
# ─────────────────────────────────────────────────────────────────────
[modules.sentinel]
enabled               = true
# Alert channel for WARN events (below gline threshold).
alert_channel         = "#opers"
# Per-event score thresholds:
#   score >= gline_threshold → GLINE for gline_duration seconds
#   score >= warn_threshold  → NOTICE to alert_channel
#   score <  warn_threshold  → log-only
dnsbl_warn_threshold  = 3
dnsbl_gline_threshold = 7
dnsbl_gline_duration  = 3600
dnsbl_gline_reason    = "Your connection was flagged by multiple DNS blocklists. Visit https://dronebl.org/lookup for delisting."
# Prefix for marks emitted by Cathexis (usually matches DNSBL_MARK there).
dnsbl_mark_prefix     = "DNSBL"

[modules.sentinel.dnsbl_scoring]
# Per-zone weights. Zones not listed here default to weight 1.
# Keys must match the zone strings Cathexis emits in DNSBL marks
# (typically the DNSBL_HOST / DNSBL_HOST2 / DNSBL_HOST3 values).
# Use weight 0 to observe a zone without contributing to the score.
"dnsbl.dronebl.org"     = 3   # aggressive — drone/bot network detection
"rbl.efnetrbl.org"      = 2   # proxy / Tor exit detection
"torexit.dan.me.uk"     = 2   # Tor exit list (specific)
"cerberus.example.org"  = 2   # your own Cerberus zone if running
# Example: weight 0 to log without auto-action:
# "some-noisy.rbl.example" = 0

# Per-zone human descriptions (for logging and alert channel messages).
[modules.sentinel.dnsbl_scoring.descriptions]
"dnsbl.dronebl.org"     = "DroneBL — known drone/bot IP"
"rbl.efnetrbl.org"      = "EFnet RBL — proxy/Tor exit"
"torexit.dan.me.uk"     = "Tor exit node"
"cerberus.example.org"  = "Cerberus — local reputation DB"